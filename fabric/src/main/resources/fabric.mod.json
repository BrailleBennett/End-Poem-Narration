{
  "schemaVersion": 1,
  "id": "end_poem_narration",
  "version": "${version}",
  "name": "End Poem Narration",
  "description": "A Fabric mod that adds EnderStarr and HarrisonGray’s English human narration to the End Poem.",
  "authors": [
    "BrailleBennett"
  ],
  "contact": {
    "sources": "https://github.com/BrailleBennett/end-poem-narration"
  },
  "license": "GPL-3.0-only",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.brlbennett.endpoemnarration.fabric.FabricMain"
    ]
  },
  "mixins": [
    "end_poem_narration.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "1.21.11",
    "java": ">=25"
  }
}
